# Copy to .env and fill in. Never commit .env.

# --- Identity ---
DOMAIN=https://vault.example.com

# Argon2 hash, NOT plaintext. Generate:
#   docker run --rm -it vaultwarden/server:1.36.0 /vaultwarden hash
# Paste the full $argon2id$... string, single-quoted if run via shell.
ADMIN_TOKEN=

# --- Signup / invites: closed instance ---
SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=true
# Optional: restrict invite emails to your domain
# SIGNUPS_DOMAINS_WHITELIST=example.com
SHOW_PASSWORD_HINT=false

# --- Audit logging (SOC 2 evidence) ---
ORG_EVENTS_ENABLED=true
EVENTS_DAYS_RETAIN=365
EXTENDED_LOGGING=true
LOG_FILE=/data/vaultwarden.log
LOG_LEVEL=info

# --- Brute-force resistance (pair with Fail2Ban on LOG_FILE) ---
LOGIN_RATELIMIT_MAX_BURST=10
LOGIN_RATELIMIT_SECONDS=60
ADMIN_RATELIMIT_MAX_BURST=3
ADMIN_RATELIMIT_SECONDS=300

# --- SMTP (required for invites, verification, emergency access) ---
SMTP_HOST=smtp.example.com
SMTP_FROM=vault@example.com
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=
SMTP_PASSWORD=

# --- Optional: mobile push (relays via Bitwarden cloud; register at bitwarden.com/host) ---
# PUSH_ENABLED=true
# PUSH_INSTALLATION_ID=
# PUSH_INSTALLATION_KEY=
